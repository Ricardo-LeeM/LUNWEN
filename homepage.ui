  <property name="styleSheet">
   <string notr="true">/*
 *  ==================================================================================
 *  ||  GOOGLE HRMS - GLACIER &amp; MINT THEME (THE FINAL CUT)                        ||
 *  ||  PHILOSOPHY: Human-Centric Clarity &amp; Effortless Vitality                 ||
 *  ==================================================================================
 */

/* ------------------- 1. 全局基石：冰川之上 (The Foundation: Glacial) ------------------- */
QWidget {
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, &quot;Helvetica Neue&quot;, &quot;Microsoft YaHei&quot;, sans-serif;
    font-size: 14px;
    /* 告别黑暗。我们用几乎看不出的、极其柔和的冷灰色作为基底。*/
    background-color: #F9FAFB;
    /* 文字使用深邃但并非100%纯黑的石墨色，清晰而不刺眼。*/
    color: #1F2937;
}


/* ------------------- 3. 核心交互：薄荷般的清爽 (A Hint of Mint) ------------------- */
/* 标签 (QLabel) */
QLabel {
    background-color: transparent;
    color: #4B5563; /* 默认标签颜色，清晰柔和 */
}
QLabel {
    color: #1F2937;
    font-weight: 600;
}

/* 按钮 (QPushButton): 清晰的行动点 */
QPushButton {
    /* 我们的活力来源：薄荷绿。它代表成功、许可、前进。*/
    background-color: #10B981;
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #059669;
}
QPushButton:pressed {
    background-color: #047857;
}

/* 输入框 (QLineEdit &amp; QTextEdit): 干净的画布 */
QLineEdit, QTextEdit {
    background-color: #F9FAFB; /* 与基底同色，或用#FFFFFF纯白亦可 */
    border: 3px solid #D1D5DB;
    border-radius: 6px;
    padding: 1px;
    color: #1F2937;
}
/* 占位符必须清晰 */
QLineEdit::placeholder-text {
    color: #9CA3AF;
}
QLineEdit:focus, QTextEdit:focus {
    border: 2px solid #10B981; /* 焦点时，薄荷绿光环清晰醒目 */
    padding: 8px; /* 边框变粗，内边距微调保持总高度不变 */
}

/* ------------------- 4. 数据展示：秩序井然 (Orderly Presentation) ------------------- */
/* 表格 (QTableWidget) */
QTabWidget::pane {
    /* 赋予内容区域一个纯白的背景，使其从#F9FAFB的基底中分离出来 */
    background-color: #FFFFFF;

    /* 定义一个清晰但柔和的边界 */
    border: 1px solid #E5E7EB;

    /* 这是核心：让内容区域拥有圆角。注意，顶部的圆角我们特殊处理，以完美融合Tab栏 */
    border-radius: 8px;
    border-top-left-radius: 0px; /* 左上角不设圆角，为选中的Tab留出空间 */
    border-top-right-radius: 8px; /* 保留右上角的圆角 */

    /* 在Tab栏下方留出一些内边距，让内容呼吸 */
    padding: 20px;

    /* 魔法：让内容区域向上移动一个像素，与Tab栏的下边框无缝衔接 */
    top: -1px;
}

QTabBar::tab {
    /* 为所有Tab设定基础样式 */
    font-size: 14px;
    font-weight: 600;
    color: #6B7280; /* 未选中时的颜色 */
    padding: 10px 20px;

    /* 默认状态下，Tab没有背景和边框，只是一段文字 */
    background-color: transparent;
    border: 1px solid transparent; /* 预留边框位置 */
    border-bottom: none; /* 底部绝不能有边框 */
    margin-right: 2px; /* Tab之间的微小间距 */
}

/* 鼠标悬停在“未选中”的Tab上：给予轻微的视觉反馈 */
QTabBar::tab:!selected:hover {
    background-color: #F3F4F6;
    color: #374151;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
}

/* “选中”的Tab：这是设计的精髓所在 */
QTabBar::tab:selected {
    /* 背景色与下方面板的白色完全一致，实现视觉上的“融合” */
    background-color: #FFFFFF;
    
    /* 字体颜色变为我们的主题色“薄荷绿” */
    color: #059669;

    /* 边框与下方面板完全一致，除了底部 */
    border: 1px solid #E5E7EB;
    
    /* 这是最关键的一步：将底边框的颜色设置为与背景色相同，从而“切开”边框，
       制造出Tab与内容面板连为一体的视觉假象。*/
    border-bottom-color: #FFFFFF;

    /* 顶部圆角，与下方容器的圆角设计相呼应 */
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
}
QHeaderView::section {
    background-color: #F9FAFB;
    border: none;
    border-bottom: 1px solid #E5E7EB;
    padding: 10px;
    font-weight: 600;
    color: #6B7280;
}
QTableView::item {
    border: none;
    padding: 12px;
}
/* 选中行，用薄荷的淡彩 */
QTableView::item:selected {
    background-color: #D1FAE5;
    color: #064E3B;
}

/* Tab选项卡 (QTabWidget) */
QTabWidget::pane {
    border: none;
}
QTabBar::tab {
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    color: #6B7280;
    padding: 10px 16px;
    font-size: 14px;
    margin-right: 8px;
}
QTabBar::tab:hover {
    background-color: #F3F4F6;
    border-bottom: 2px solid #D1D5DB;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
}
QTabBar::tab:selected {
    color: #059669;
    font-weight: bold;
    border-bottom: 2px solid #10B981;
}

/* ------------------- 5. 滚动条：无感的细节 (Invisible Details) ------------------- */
QScrollBar:vertical, QScrollBar:horizontal {
    border: none;
    background: #F9FAFB;
    width: 10px;
    height: 10px;
}
QScrollBar::handle {
    background: #D1D5DB;
    border-radius: 5px;
}
QScrollBar::handle:hover {
    background: #9CA3AF;
}</string>
