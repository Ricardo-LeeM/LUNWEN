     <property name="styleSheet">
      <string notr="true">/* ScrollArea Styling (if not covered by global QWidget) */
QScrollArea {
    border: none; /* Often scroll areas themselves don't need a border if their content does */
    background-color: transparent; /* Or #FFFFFF if you want it to have a white bg */
}

/* ScrollBar Styling (Consistent and modern) */
QScrollBar:vertical {
    border: 1px solid #D0D3D4;
    background-color: #F0F0F0;
    width: 14px; /* Slightly wider for easier clicking */
    margin: 0px 0px 0px 0px;
    border-radius: 3px;
}
QScrollBar::handle:vertical {
    background-color: #B0B0B0; /* Medium gray handle */
    min-height: 25px;
    border-radius: 3px;
    margin: 1px;
}
QScrollBar::handle:vertical:hover {
    background-color: #909090; /* Darker on hover */
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    border: none;
    background: none;
    height: 0px; /* Hide default arrows, or style them if desired */
    subcontrol-position: top;
    subcontrol-origin: margin;
}
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

QScrollBar:horizontal {
    border: 1px solid #D0D3D4;
    background-color: #F0F0F0;
    height: 14px;
    margin: 0px 0px 0px 0px;
    border-radius: 3px;
}
QScrollBar::handle:horizontal {
    background-color: #B0B0B0;
    min-width: 25px;
    border-radius: 3px;
    margin: 1px;
}
QScrollBar::handle:horizontal:hover {
    background-color: #909090;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    border: none;
    background: none;
    width: 0px;
    subcontrol-position: left;
    subcontrol-origin: margin;
}
QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: none;
}
</string>
