     <widget class="QTabWidget" name="tabWidget">
      <property name="styleSheet">
       <string notr="true">QTabWidget::pane {
    border: 1px solid #D0D3D4; /* Light border for the content pane */
    border-top: none; /* Tab bar will cover top */
    background-color: #FFFFFF; /* White background for tab content area */
    border-bottom-left-radius: 5px;
    border-bottom-right-radius: 5px;
    padding: 15px;
}

QTabBar::tab {
    background-color: #EAECEE; /* Light gray for inactive tabs */
    color: #566573;
    border: 1px solid #D0D3D4;
    border-bottom: none; /* To merge with pane */
    padding: 10px 25px; /* Generous padding */
    font-weight: bold;
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
    margin-right: 2px; /* Spacing between tabs */
}

QTabBar::tab:selected {
    background-color: #FFFFFF; /* Selected tab matches content pane background */
    color: #2980B9; /* A professional blue for selected tab text */
    border-bottom: 1px solid #FFFFFF; /* Make it look like it's part of the pane */
}

QTabBar::tab:hover:!selected {
    background-color: #D5D8DC; /* Slightly darker on hover for inactive tabs */
}

QTabBar::tab:last {
    margin-right: 0; /* No margin for the last tab */
}</string>
