        <widget class="QTextEdit" name="textEdit_1">
         <property name="geometry">
          <rect>
           <x>80</x>
           <y>90</y>
           <width>441</width>
           <height>101</height>
          </rect>
         </property>
         <property name="styleSheet">
          <string notr="true">QTextEdit {
    background-color: white; /* 设置背景为白色 */
    border: 2px solid #ccc; /* 设置边框为灰色，宽度为2px */
    border-radius: 15px; /* 设置圆角大小为15px，可根据需要调整 */
    padding: 10px; /* 设置内边距为10px，让文字和边框之间有空间 */
    font-size: 14px; /* 设置字体大小 */
    color: black; /* 设置文字颜色为黑色 */
}

QTextEdit:focus {
    border: 2px solid #0078d7; /* 当文本框获得焦点时，边框变为蓝色 */
}</string>
         </property>
        </widget>
        <widget class="QLabel" name="labName_4">
         <property name="geometry">
          <rect>
           <x>10</x>
           <y>50</y>
           <width>91</width>
           <height>19</height>
          </rect>
         </property>
         <property name="styleSheet">
          <string notr="true">QLabel {
    background-color: transparent; /* Keep background transparent */
    color: #0D47A1;              /* A distinct, professional, and consistent DEEP BLUE for ALL labels.
                                     This is clearly not black or dark gray.
                                     Alternatives:
                                     #1565C0 (Slightly brighter, still very blue)
                                     #2E7D32 (If you preferred a deep green)
                                     #5E35B1 (If you preferred a deep purple) */
    font-size: 10pt;                /* UNIFIED font size for ALL labels.
                                     This size is generally good for readability without being too large.
                                     Adjust to 10pt if 9pt feels slightly too small across the board. */
    font-weight: normal;           /* UNIFIED font weight for ALL labels.
                                     Avoids unintended emphasis. */
    padding: 2px;                  /* Minimal and UNIFIED padding for ALL labels. */
    /* Remove any previous margin or specific alignment settings to ensure uniformity */
    margin: 0px;
    qproperty-alignment: 'AlignVCenter | AlignLeft'; /* Default alignment, can be overridden by layout */
}
</string>
         </property>
         <property name="text">
          <string>申  报  人</string>
         </property>
        </widget>
        <widget class="QLineEdit" name="lineEditName_1">
         <property name="geometry">
          <rect>
           <x>110</x>
           <y>50</y>
           <width>181</width>
           <height>21</height>
          </rect>
         </property>
         <property name="styleSheet">
          <string notr="true">/* LineEdit and TextEdit Styling */
QLineEdit, QTextEdit {
    background-color: #FFFFFF;
    border: 1px solid #BDC3C7; /* Softer border color */
    border-radius: 4px;
    padding: 1px;
    color: #2C3E50;
    selection-background-color: #AED6F1; /* Light blue selection */
    selection-color: #1A5276;
}

QLineEdit:focus, QTextEdit:focus {
    border: 1px solid #3498DB; /* Highlight border on focus - a clear, friendly blue */
    /* box-shadow: 0 0 3px #3498DB;  Unfortunately, box-shadow is not well supported in QSS */
}

QLineEdit:read-only, QTextEdit:read-only {
    background-color: #ECF0F1; /* Slightly different background for read-only fields */
    color: #7F8C8D;
}</string>
         </property>
        </widget>
