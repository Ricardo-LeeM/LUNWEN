        <property name="styleSheet">
         <string notr="true">/* QLabel Styling */
QLabel {
    background-color: transparent; /* Ensure labels don't have unwanted backgrounds */
    color: #2980B9; /* Consistent dark text color */
    padding: 2px;
}

QLabel { /* For larger titles, set objectName=&quot;titleLabel&quot; */
    font-size: 16pt;
    font-weight: bold;
    color: #2C3E50;
    padding-bottom: 10px;
}

QLabelLabel { /* For &quot;欢迎来到...&quot; and &quot;晚上好&quot; */
    font-size: 18pt;
    font-weight: 500; /* A bit lighter than bold */
    color: #2C3E50;
    padding: 10px 0;
}</string>
