         <property name="styleSheet">
          <string notr="true">QLabel {
    background-color: transparent; /* Keep background transparent */
    color: #0D47A1;              /* A distinct, professional, and consistent DEEP BLUE for ALL labels.
                                     This is clearly not black or dark gray.
                                     Alternatives:
                                     #1565C0 (Slightly brighter, still very blue)
                                     #2E7D32 (If you preferred a deep green)
                                     #5E35B1 (If you preferred a deep purple) */
    font-size: 12pt;                /* UNIFIED font size for ALL labels.
                                     This size is generally good for readability without being too large.
                                     Adjust to 10pt if 9pt feels slightly too small across the board. */
    font-weight: normal;           /* UNIFIED font weight for ALL labels.
                                     Avoids unintended emphasis. */
    padding: 2px;                  /* Minimal and UNIFIED padding for ALL labels. */
    /* Remove any previous margin or specific alignment settings to ensure uniformity */
    margin: 0px;
    qproperty-alignment: 'AlignVCenter | AlignLeft'; /* Default alignment, can be overridden by layout */
}
</string>
