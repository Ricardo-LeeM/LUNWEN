  <property name="styleSheet">
   <string notr="true">QWidget {
    font-family: &quot;Microsoft YaHei&quot;, &quot;Segoe UI&quot;, &quot;Helvetica Neue&quot;, Arial, sans-serif;
    font-size: 10pt;
    color: #2c3e50;
    background-color: #f4f6f8;
}
QPushButton {
    background-color: #3498db;
    color: white;
    border: none;
    padding: 8px 16px;
    border-radius: 4px;
    min-width: 80px; /* 设置最小宽度 */
}

QPushButton:hover {
    background-color: #5dade2; /* 悬浮时变亮 */
}

QPushButton:pressed {
    background-color: #2980b9; /* 按下时变深 */
}

/* 禁用状态的按钮 */
QPushButton:disabled {
    background-color: #bdc3c7;
    color: #7f8c8d;
}

/* 特定功能按钮 (通过 objectName 设置) */
/* 例如，删除按钮可以使用红色 */
QPushButton#deleteButton, QPushButton#btnDeleteRow {
    background-color: #e74c3c;
}
QPushButton#deleteButton:hover, QPushButton#btnDeleteRow:hover {
    background-color: #f1948a;
}
QPushButton#deleteButton:pressed, QPushButton#btnDeleteRow:pressed {
    background-color: #c0392b;
}

/* 次要按钮 (例如: 适应列宽/行高) */
QPushButton#btnAutoAdjustColumnWidth, QPushButton#btnAutoAdjustRowHeigth {
    background-color: #95a5a6;
}
QPushButton#btnAutoAdjustColumnWidth:hover, QPushButton#btnAutoAdjustRowHeigth:hover {
    background-color: #aeb6bf;
}
QPushButton#btnAutoAdjustColumnWidth:pressed, QPushButton#btnAutoAdjustRowHeigth:pressed {
    background-color: #7f8c8d;
}</string>
